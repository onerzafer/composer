{
  "name": "composer-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Composer — Schema-Compiled Composition toolkit (monorepo)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onerzafer/composer.git"
  },
  "homepage": "https://github.com/onerzafer/composer#readme",
  "bugs": {
    "url": "https://github.com/onerzafer/composer/issues"
  },
  "author": "Öner Zafer",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
