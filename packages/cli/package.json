{
  "name": "@composer/cli",
  "version": "0.1.0-alpha.0",
  "description": "Composer CLI — composer init / compose / validate / explain / trace / doctor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onerzafer/composer.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/onerzafer/composer#readme",
  "bugs": {
    "url": "https://github.com/onerzafer/composer/issues"
  },
  "author": "Öner Zafer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "composer": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@composer/adapter-kit": "workspace:*",
    "@composer/core": "workspace:*",
    "commander": "^12.1.0",
    "@composer/ingest-kit": "workspace:*",
    "@composer/grammar-kit": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
