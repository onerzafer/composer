{
  "name": "@composer/ingest-kit",
  "version": "0.1.0-alpha.0",
  "description": "SDK for authoring Composer ingester plugins (the reverse codec of an adapter).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@composer/adapter-kit": "workspace:*",
    "typescript": "^5.4.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  }
}
