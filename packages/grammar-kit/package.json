{
  "name": "@composer/grammar-kit",
  "version": "0.1.0-alpha.0",
  "description": "Guided, human-owned vocabulary authoring for Composer — AI skills + deterministic staging/quality helpers (the forward complement of ingest-kit).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onerzafer/composer.git",
    "directory": "packages/grammar-kit"
  },
  "homepage": "https://github.com/onerzafer/composer#readme",
  "bugs": {
    "url": "https://github.com/onerzafer/composer/issues"
  },
  "author": "Öner Zafer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest.json": "./manifest.json"
  },
  "files": [
    "dist",
    "skills",
    "templates",
    "taxonomy",
    "scripts",
    "manifest.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@composer/adapter-kit": "workspace:*",
    "@composer/core": "workspace:*",
    "@composer/ingest-kit": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
