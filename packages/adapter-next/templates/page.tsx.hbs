{{!-- adapter-next Page template — emits src/app/<slug>/page.tsx.
     Imports are collected up front (import declarations can't sit inside the
     function body); each tree node's markup is delegated to its own
     primitive's template via {{renderPrimitive}} (template-per-primitive
     model, docs/adapters/authoring.md §2) — this file only owns page-level
     plumbing, not any embedded primitive's markup. --}}
{{!-- from: {{spec_path}} primitive=Page slug={{slug}} --}}
import type { Metadata } from "next";
{{#each tree}}
{{#if (eq primitive "Hero")}}
import { {{slot "Hero" variant}} } from {{{json (slot "Hero" variant "importPath")}}};
{{/if}}
{{/each}}

export const metadata: Metadata = { title: {{{json title}}} };

export default function {{kebab slug}}Page() {
  return (
    <main className="container mx-auto px-4 py-12">
{{#each tree}}
      {{indent 6 (renderPrimitive this)}}
{{/each}}
    </main>
  );
}
