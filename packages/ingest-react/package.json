{
  "name": "@composer/ingest-react",
  "version": "0.1.0-alpha.0",
  "description": "Composer ingester plugin: derive primitive drafts from React (.tsx) components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onerzafer/composer.git",
    "directory": "packages/ingest-react"
  },
  "homepage": "https://github.com/onerzafer/composer#readme",
  "bugs": {
    "url": "https://github.com/onerzafer/composer/issues"
  },
  "author": "Öner Zafer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@composer/ingest-kit": "workspace:*",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
