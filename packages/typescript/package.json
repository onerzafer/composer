{
  "name": "@composer/typescript",
  "version": "0.1.0-alpha.0",
  "description": "Composer catalog-authoring engine (Zod + superRefine, TypeScript loader)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onerzafer/composer.git",
    "directory": "packages/typescript"
  },
  "homepage": "https://github.com/onerzafer/composer#readme",
  "bugs": {
    "url": "https://github.com/onerzafer/composer/issues"
  },
  "author": "Öner Zafer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@composer/adapter-kit": "workspace:*",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  }
}
